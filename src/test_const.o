MODULE Primes;

IMPORT In, Out;

VAR
   n, c, i, d : INTEGER;
   v : BOOLEAN;
BEGIN

   In.Open;
   In.Int(n);
   c := 0;
   i := 2;
   WHILE i <= n DO
         d := 2;
         WHILE i MOD d # 0 DO
            INC(d)
         END;
      IF d = i THEN (* i - ¯à®áâ®¥ *)
         INC(c);
         Out.Int(d, 8)
      END;
      INC(i);
   END;

   c :=0;
   i := 2;
   d := 0;

   WHILE i <= n DO
            d := 2;
            WHILE i MOD d # 0 DO
               INC(d)
            END;
         IF d = i THEN (* i - ¯à®áâ®¥ *)
            INC(c);
            Out.Int(d, 8)
         END;
         INC(i);
      END;
   Out.Ln();
   Out.Int(c, 0);
END Primes.